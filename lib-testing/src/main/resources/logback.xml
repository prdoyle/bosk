<configuration>
 	<turboFilter class="works.bosk.logback.RecordingTurboFilter">
 		<routingKey>bosk.instanceID</routingKey>
 		<filter class="works.bosk.logback.LoggerLevelFilter">
			<logger> <name>com.mongodb</name> <level>INFO</level> </logger>
			<logger> <name>org.mongodb</name> <level>INFO</level> </logger>
			<logger> <name>works.bosk.drivers.mongo.internal.MongoService</name> <level>INFO</level> </logger>
 		</filter>
 	</turboFilter>
	<turboFilter class="works.bosk.logback.BoskLogFilter"/>
	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d %-5level [%thread] [%X{bosk.name}]%X{bosk.MongoDriver.transaction}%X{bosk.MongoDriver.event} %logger{25}: %msg%n</pattern>
		</encoder>
		<immediateFlush>true</immediateFlush>
	</appender>
	<root level="WARN">
		<appender-ref ref="CONSOLE" />
	</root>

	<!-- This emits warnings that matter in production but not in tests -->
	<logger name="works.bosk.drivers.mongo.MongoDriver.uninitializedCollection" level="ERROR"/>

	<!-- How to add more tracing during unit tests
	<logger name="works.bosk" level="INFO"/>
	<logger name="works.bosk.boson" level="DEBUG"/>
	<logger name="works.bosk.bosonSerializer" level="DEBUG"/>
	<logger name="works.bosk.drivers.sql" level="DEBUG"/>
	<logger name="works.bosk.test.drivers.DriverConformanceTest" level="DEBUG"/>
	<logger name="works.bosk.drivers.mongo" level="DEBUG"/>
	<logger name="works.bosk.drivers.mongo.internal.ChangeReceiver" level="DEBUG"/>
	<logger name="works.bosk.drivers.mongo.internal.MainDriver" level="DEBUG"/>
	<logger name="works.bosk.drivers.mongo.internal.PandoFormatDriver" level="DEBUG"/>
	<logger name="works.bosk.drivers.mongo.internal.AbstractMongoDriverTest" level="DEBUG"/>
	<logger name="works.bosk.logback.BoskLogFilter" level="DEBUG"/>
	 -->

</configuration>
