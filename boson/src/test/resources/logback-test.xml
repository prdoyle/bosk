<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="works.bosk.json.codec.interpreter.SpecInterpretingParser" level="DEBUG" />
    <!-- Example of a specific logger configuration -->
<!--    <logger name="works.bosk.json.codec.compiler.SpecCompiler" level="DEBUG" />-->
</configuration>
